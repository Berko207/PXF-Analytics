# Copy to .env.local and fill in from Supabase Dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# Server-only (admin actions). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Prediction markets (Rain)
# =============================================================================
# Provider: "mock" (default, in-memory sim) or "rain" (onchain).
NEXT_PUBLIC_MARKETS_PROVIDER=mock

# Chain the whole app talks to (client wallet + server executor share this).
#   arbitrum-sepolia  → TESTNET, trade with fake-value tokens (recommended first)
#   arbitrum-one      → MAINNET, real money
NEXT_PUBLIC_CHAIN=arbitrum-sepolia

# Symbol shown in the bet UI (cosmetic). Defaults: USDC on testnet, USDT on mainnet.
NEXT_PUBLIC_TOKEN_SYMBOL=USDC

# Master broadcast switch. Markets are only ever sent onchain when this is
# exactly "true". Leave unset/false to PREP markets (build + persist) without
# transacting. Keep off until wallets/keys are funded and compliance is cleared.
MARKETS_LIVE=false

# Custody model for execution: "custodial" (RainAA smart accounts, server-side,
# gas-sponsored) or "connected" (the user's own wallet, client-side).
# The Connect-Wallet bet flow uses "connected" — fans sign their own buys.
RAIN_CUSTODY=connected

# Rain environment + endpoints.
RAIN_ENVIRONMENT=development          # development | stage | production
RAIN_RPC_URL=                         # optional — defaults to public Arbitrum RPC
RAIN_WS_RPC_URL=                      # required for live price subscriptions
RAIN_SUBGRAPH_URL=                    # required for trade history / indexer
RAIN_SUBGRAPH_API_KEY=

# Custodial execution (server-only — never prefix with NEXT_PUBLIC_).
ALCHEMY_API_KEY=
RAIN_PAYMASTER_POLICY_ID=
RAIN_SIGNER_PRIVATE_KEY=              # 0x… EOA that derives the smart account
RAIN_CREATOR_ADDRESS=                # wallet that creates/owns markets (0x…)

# Market economics. DEFAULT base token is mainnet USDT — on testnet you MUST
# set RAIN_BASE_TOKEN to the test token the Rain `development` env settles in.
RAIN_BASE_TOKEN=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
RAIN_TOKEN_DECIMALS=6
RAIN_SEED_LIQUIDITY_WEI=10000000

# Admin gate for /api/markets/* before the auth UI ships (server-only secret).
MARKETS_ADMIN_SECRET=

# =============================================================================
# TESTNET QUICKSTART — trade end-to-end with no real money
# =============================================================================
# 1. NEXT_PUBLIC_MARKETS_PROVIDER=rain
# 2. NEXT_PUBLIC_CHAIN=arbitrum-sepolia   (and confirm RAIN_ENVIRONMENT=development
#    actually targets Arbitrum Sepolia — set RAIN_RPC_URL to a Sepolia RPC).
# 3. RAIN_CUSTODY=connected                (fans sign their own buys)
# 4. RAIN_BASE_TOKEN + RAIN_TOKEN_DECIMALS = the testnet settlement token.
# 5. Create a market: MARKETS_LIVE=true + custodial creator keys (RAIN_SIGNER_
#    PRIVATE_KEY, ALCHEMY_API_KEY, RAIN_PAYMASTER_POLICY_ID, RAIN_CREATOR_ADDRESS),
#    then POST /api/markets/create with the x-admin-secret header. The fan buy
#    flow itself needs none of those server keys — only the wallet.
# 6. In the app: Connect Wallet (header) → open a bout → Place bet → sign.
