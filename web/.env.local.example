# Copy to .env.local and fill in from Supabase Dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-or-anon-key>

# Server-only (admin actions). Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Prediction markets (Rain)
# =============================================================================
# Provider: "mock" (default, in-memory sim) or "rain" (Arbitrum One).
NEXT_PUBLIC_MARKETS_PROVIDER=mock

# Master broadcast switch. Markets are only ever sent onchain when this is
# exactly "true". Leave unset/false to PREP markets (build + persist) without
# transacting. Keep off until wallets/keys are funded and compliance is cleared.
MARKETS_LIVE=false

# Custody model for execution: "custodial" (RainAA smart accounts, server-side,
# gas-sponsored) or "connected" (the user's own wallet, client-side).
RAIN_CUSTODY=custodial

# Rain environment + endpoints.
RAIN_ENVIRONMENT=development          # development | stage | production
RAIN_RPC_URL=                         # optional — defaults to public Arbitrum RPC
RAIN_WS_RPC_URL=                      # required for live price subscriptions
RAIN_SUBGRAPH_URL=                    # required for trade history / indexer
RAIN_SUBGRAPH_API_KEY=

# Custodial execution (server-only — never prefix with NEXT_PUBLIC_).
ALCHEMY_API_KEY=
RAIN_PAYMASTER_POLICY_ID=
RAIN_SIGNER_PRIVATE_KEY=              # 0x… EOA that derives the smart account
RAIN_CREATOR_ADDRESS=                # wallet that creates/owns markets (0x…)

# Market economics (defaults: USDT on Arbitrum, 6 decimals, 10 USDT seed).
RAIN_BASE_TOKEN=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
RAIN_TOKEN_DECIMALS=6
RAIN_SEED_LIQUIDITY_WEI=10000000

# Admin gate for /api/markets/* before the auth UI ships (server-only secret).
MARKETS_ADMIN_SECRET=
